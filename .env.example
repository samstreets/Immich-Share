# Copy this to .env and fill in your values
# cp .env.example .env

# ── Immich connection ────────────────────────────────────────────────────────
# URL of your Immich server (no trailing slash)
IMMICH_URL=http://192.168.1.100:2283

# API key from Immich → Account Settings → API Keys
IMMICH_API_KEY=your-immich-api-key-here

# ── This app ─────────────────────────────────────────────────────────────────
# The public URL this app is reachable at (used to build share links)
EXTERNAL_URL=https://share.yourdomain.com

# Secret for signing admin JWT tokens — use a long random string!
JWT_SECRET=change-me-to-a-very-long-random-secret-string

# Default admin password (only applied on first run if no admin exists)
ADMIN_PASSWORD=admin

# Port to listen on (default: 3000)
PORT=3000

# Docker image tag (used by docker-compose if pulling from registry)
DOCKER_IMAGE=samuelstreets/immich-share:latest
